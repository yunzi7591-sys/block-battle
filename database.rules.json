{
  "rules": {
    "rooms": {
      ".read": "auth != null",
      ".indexOn": ["status", "createdAt"],
      "$roomId": {
        ".write": "auth != null && (
          (!data.exists())
          || (data.child('player1/uid').val() === auth.uid)
          || (data.child('player2/uid').val() === auth.uid)
          || (
            !data.child('player2').exists()
            && data.child('status').val() === 'waiting'
            && newData.child('player2/uid').val() === auth.uid
          )
        )",
        ".validate": "newData.hasChildren(['status', 'player1', 'board', 'currentTurn'])",

        "player1": {
          ".validate": "newData.hasChildren(['uid', 'name', 'rate'])"
        },
        "player2": {
          ".validate": "newData.hasChildren(['uid', 'name', 'rate'])"
        },
        "status": {
          ".validate": "newData.val() === 'waiting' || newData.val() === 'playing' || newData.val() === 'finished'"
        },
        "board": {
          ".validate": "newData.hasChildren(['0','1','2','3','4','5','6','7'])"
        },
        "currentTurn": {
          ".validate": "newData.isString()"
        },
        "placedCount": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3"
        },
        "turnNumber": {
          ".validate": "newData.isNumber() && newData.val() >= 1"
        },
        "turnDuration": {
          ".validate": "newData.isNumber() && newData.val() >= 10000 && newData.val() <= 120000"
        },
        "winner": {
          ".write": "auth != null && !data.exists()",
          ".validate": "newData.isString()"
        },
        "loser": {
          ".write": "auth != null && !data.exists()",
          ".validate": "newData.isString()"
        },
        "isFinished": {
          ".validate": "newData.isBoolean()"
        },
        "isRanked": {
          ".validate": "newData.isBoolean()"
        },
        "isPrivate": {
          ".validate": "newData.isBoolean()"
        }
      }
    },

    "leaderboard": {
      ".read": "auth != null",
      ".write": false
    },

    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth.uid === $uid",
        ".validate": "newData.hasChildren(['name'])"
      }
    },

    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
